<idea-plugin>
    <id>com.rostyslavpaliuha.consolesoundnotificatier</id>
    <name>Console Sound Notifier</name>
    <vendor email="rostyslavpaliuha@gmail.com" url="https://www.linkedin.com/in/rostyslavpaliuha/">
        Rostyslav Paliuha
    </vendor>
    <description><![CDATA[
                 Console Sound Notifier helps developers monitor IntelliJ IDEA console output and receive audible alerts when specific keywords appear.

                 <h2>Overview</h2>
                 <p>
                     <b>Console Sound Notifier</b> enhances your development workflow by monitoring console output
                     and playing a sound when a configured keyword appears.
                 </p>

                 <p>
                     It is useful when you want to be instantly notified about important log events without constantly
                     watching the console manually. The plugin includes four built-in sounds out of the box.
                 </p>

                 <h2>Use Cases</h2>
                 <ul>
                     <li>Get notified when a build finishes or an error occurs.</li>
                     <li>Detect specific log messages without constant manual monitoring.</li>
                     <li>Improve productivity by receiving audible alerts for important events.</li>
                 </ul>
                 ]]>
    </description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <consoleFilterProvider
                implementation="com.rostyslav.consolenotification.filter.consoletext.provider.ConsoleTextFilterProvider"/>
        <toolWindow id="Console Sound Notifier"
                    factoryClass="com.rostyslav.consolenotification.ui.ConsoleSoundNotifierToolWindowFactory"
                    icon="/icon/speakerToolWindow.svg"
                    secondary="false"/>
        <notificationGroup id="Console Sound Notifier"
                           displayType="BALLOON"/>
    </extensions>

    <actions>
        <action id="OpenBindingPanelAction"
                class="com.rostyslav.consolenotification.action.OpenBindingPanelAction"
                text="Notify on Selected Text">
            <add-to-group group-id="ConsoleView.PopupMenu" anchor="last"/>
        </action>

        <action id="OpenToolWindowAction"
                class="com.rostyslav.consolenotification.action.OpenToolWindowAction"
                text="Console Sound Notifier"
                description="Open the Console Sound Notifier Tool Window"
                icon="/icon/speaker.svg">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

    </actions>
    <applicationListeners>
        <listener class="com.rostyslav.consolenotification.configuration.PluginSettingsInitializer"
                  topic="com.intellij.openapi.project.ProjectManagerListener"/>
    </applicationListeners>

</idea-plugin>
